{
  "$defs": {
    "ArtifactFile": {
      "properties": {
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "path",
        "content"
      ],
      "title": "ArtifactFile",
      "type": "object"
    },
    "Defect": {
      "properties": {
        "severity": {
          "default": "P1",
          "enum": [
            "P0",
            "P1",
            "P2"
          ],
          "title": "Severity",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "owner": {
          "anyOf": [
            {
              "enum": [
                "coder",
                "code_tester",
                "test_planner",
                "prd_planner"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Owner"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "Defect",
      "type": "object"
    },
    "UIArtifactLink": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "label",
        "path"
      ],
      "title": "UIArtifactLink",
      "type": "object"
    },
    "UITestResult": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "default": "",
          "title": "Title",
          "type": "string"
        },
        "kind": {
          "enum": [
            "web",
            "native"
          ],
          "title": "Kind",
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "skipped",
            "warning"
          ],
          "title": "Status",
          "type": "string"
        },
        "target": {
          "default": "",
          "title": "Target",
          "type": "string"
        },
        "driver": {
          "anyOf": [
            {
              "enum": [
                "cua",
                "playwright"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Driver"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "observations": {
          "items": {
            "type": "string"
          },
          "title": "Observations",
          "type": "array"
        },
        "artifacts": {
          "items": {
            "$ref": "#/$defs/UIArtifactLink"
          },
          "title": "Artifacts",
          "type": "array"
        }
      },
      "required": [
        "id",
        "kind",
        "status"
      ],
      "title": "UITestResult",
      "type": "object"
    }
  },
  "properties": {
    "verify_report": {
      "title": "Verify Report",
      "type": "string"
    },
    "passed": {
      "title": "Passed",
      "type": "boolean"
    },
    "failure_notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Failure Notes"
    },
    "defects": {
      "items": {
        "$ref": "#/$defs/Defect"
      },
      "title": "Defects",
      "type": "array"
    },
    "ux_notes": {
      "items": {
        "type": "string"
      },
      "title": "Ux Notes",
      "type": "array"
    },
    "delivery_recommendations": {
      "items": {
        "type": "string"
      },
      "title": "Delivery Recommendations",
      "type": "array"
    },
    "ui_results": {
      "items": {
        "$ref": "#/$defs/UITestResult"
      },
      "title": "Ui Results",
      "type": "array"
    },
    "ui_warnings": {
      "items": {
        "type": "string"
      },
      "title": "Ui Warnings",
      "type": "array"
    },
    "adversarial_tests": {
      "items": {
        "$ref": "#/$defs/ArtifactFile"
      },
      "title": "Adversarial Tests",
      "type": "array"
    },
    "test_files": {
      "items": {
        "$ref": "#/$defs/ArtifactFile"
      },
      "title": "Test Files",
      "type": "array"
    }
  },
  "required": [
    "verify_report",
    "passed"
  ],
  "title": "VerificationArtifact",
  "type": "object"
}